# ── Server ──────────────────────────────────────────────
PORT=4000

# ── Supabase ────────────────────────────────────────────
# Leave these blank to run on local JSON file storage (no setup needed).
# Fill them in once you create your Supabase project to switch to real persistence.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Admin login (used only while SUPABASE_URL is blank) ──
# Lets you log into /admin locally before Supabase Auth is wired up.
DEV_ADMIN_EMAIL=admin@teen4teen.org
DEV_ADMIN_PASSWORD=changeme123

# ── Gemini API (AI mock session) ───────────────────────
# Leave blank to use the built-in scripted demo conversation instead.
GEMINI_API_KEY=

# ── Email notifications (Resend) ───────────────────────
# Leave blank to skip emails — actions still work, just silently skip notifying.
RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=admin@teen4teen.org
